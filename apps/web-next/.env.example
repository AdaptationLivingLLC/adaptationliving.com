# ==========================================================================
# Adaptation OS — web-next env vars
# Copy to .env.local for local dev; set in Vercel Dashboard for production.
# ==========================================================================

# ---- Public (NEXT_PUBLIC_*) ----------------------------------------------
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_PORTAL_URL=https://app.adaptationliving.com

# ---- Stripe --------------------------------------------------------------
# sk_live_... (production) or sk_test_... (test mode)
STRIPE_SECRET_KEY=
# Create a webhook endpoint at https://adaptationliving.com/api/stripe/webhook
# listening for `checkout.session.completed`. Copy the signing secret here.
STRIPE_WEBHOOK_SECRET=

# ---- GoHighLevel agency API ----------------------------------------------
# Agency Settings -> Company -> API Key (or v2 agency-level private integration)
GHL_AGENCY_API_KEY=
# Agency Settings -> Company -> Agency ID (companyId)
GHL_AGENCY_ID=
# Snapshot IDs per tier (GHL -> Agency View -> Snapshots -> ... copy ID)
GHL_SNAPSHOT_STARTER=
GHL_SNAPSHOT_GROWTH=
GHL_SNAPSHOT_SCALE=

# ---- Email (Resend) ------------------------------------------------------
RESEND_API_KEY=
MAIL_FROM="Adaptation OS <onboarding@adaptationliving.com>"
